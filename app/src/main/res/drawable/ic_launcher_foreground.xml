<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Subtle clock shadow for high-end professional appearance -->
    <path
        android:fillColor="#000000"
        android:alpha="0.18"
        android:pathData="M 54, 55.5 m -18, 0 a 18,18 0 1,1 36,0 a 18,18 0 1,1 -36,0" />

    <!-- Outermost Watch/Clock Bezel Rim -->
    <path
        android:strokeColor="#414654"
        android:strokeWidth="2.5"
        android:fillColor="#121212"
        android:pathData="M 54, 54 m -18, 0 a 18,18 0 1,1 36,0 a 18,18 0 1,1 -36,0" />

    <!-- Inner Dial Glass Edge Rim -->
    <path
        android:strokeColor="#1A1D24"
        android:strokeWidth="1"
        android:fillColor="#00000000"
        android:pathData="M 54, 54 m -16.5, 0 a 16.5,16.5 0 1,1 33,0 a 16.5,16.5 0 1,1 -33,0"
        android:alpha="0.5" />

    <!-- Hour Hand (Pointing to 10 O'Clock) - Neon Green -->
    <path
        android:strokeColor="#39FF14"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:pathData="M 54, 54 L 46, 49" />

    <!-- Minute Hand (Pointing to 2 O'Clock) - Neon Green -->
    <path
        android:strokeColor="#39FF14"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:pathData="M 54, 54 L 65, 47.5" />

    <!-- Dial Center Cap Pin (Neon Green) -->
    <path
        android:fillColor="#39FF14"
        android:pathData="M 54, 54 m -2, 0 a 2,2 0 1,1 4,0 a 2,2 0 1,1 -4,0" />

    <!-- Center pin accent dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 53.6, 53.6 m -0.6, 0 a 0.6,0.6 0 1,1 1.2,0 a 0.6,0.6 0 1,1 -1.2,0"
        android:alpha="0.8" />

</vector>
